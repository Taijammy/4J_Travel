# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/taskflow
# MongoDB Atlas (uncomment and replace when deploying):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/taskflow

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── Cookie ────────────────────────────────────────────────────────
COOKIE_MAX_AGE_MS=604800000

# ── CORS ──────────────────────────────────────────────────────────
# The URL of your frontend (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173